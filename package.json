{
  "name": "ai-boilerplate",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "start": "npm run start -w apps/backend & npm run start -w apps/frontend & wait",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build:shared": "npm run build -w packages/shared",
    "build:utils": "npm run build -w packages/utils",
    "build:backend": "npm run build -w apps/backend",
    "build:frontend": "npm run build -w apps/frontend",
    "build": "npm run build:shared && npm run build:utils && npm run build:backend && npm run build:frontend",
    "test": "npm run test --workspaces --if-present",
    "test:shared": "npm run test -w packages/shared",
    "test:utils": "npm run test -w packages/utils",
    "test:backend": "npm run test -w apps/backend",
    "test:frontend": "npm run test -w apps/frontend",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc -b",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20.14.0",
    "husky": "^9.1.7",
    "typescript": "^5.5.0"
  }
}
